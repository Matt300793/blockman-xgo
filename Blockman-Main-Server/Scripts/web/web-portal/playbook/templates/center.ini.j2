[program:{{ service }}]
command=/usr/bin/java -jar -Xms{{ jvm_min_heap_memory }}m -Xmx{{ jvm_max_heap_memory }}m -Xss256k -Dfile.encoding=UTF-8 -Dspring.profiles.active={{ profile_name }} /home/deploy/apps/{{ service }}-0.0.1-SNAPSHOT.jar
user=deploy
autostart=true
autorestart=true
startsecs=10
startretries=5
stdout_logfile=/home/deploy/logs/supervisor/{{ service }}.log
stderr_logfile=/home/deploy/logs/supervisor/{{ service }}-error.log
logfile_maxbytes=133432448
logfile_backups=10