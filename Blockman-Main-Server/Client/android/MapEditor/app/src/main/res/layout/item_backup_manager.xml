<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:bind="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="ViewModel"
            type="com.sandboxol.mapeditor.view.fragment.backupmanager.BackupManageItemViewModel"/>

        <import type="com.sandboxol.mapeditor.R"/>

        <import type="android.view.View"/>
    </data>

    <com.sandboxol.mapeditor.view.widget.LineItemView
        style="@style/MapListItemStyle">

        <LinearLayout
            style="@style/MapListItemContentStyle"
            bind:onClickCommand="@{ViewModel.onItemClickCommand}">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical">

                <View
                    style="@style/McMapIconStyle"
                    android:background="@mipmap/bg_backup_mana_icon"/>

                <com.sandboxol.mapeditor.view.widget.RoundImageView
                    style="@style/SmallMcMapIconStyle"
                    bind:borderRadius="@dimen/space6dp"
                    bind:failedImageRes="@{R.mipmap.ic_map_default}"
                    bind:placeImageRes="@{R.mipmap.ic_map_default}"
                    bind:type="round"
                    bind:uri="@{ViewModel.image}"/>

            </RelativeLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lines="1"
                    android:text="@{ViewModel.name}"
                    android:textColor="@color/color_dialog_content_text"
                    android:textSize="@dimen/textSize15Sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space8dp"
                    android:text="@{ViewModel.lately}"
                    android:textColor="@color/color_hint_text"
                    android:textSize="@dimen/textSize11Sp"
                    android:visibility="@{ViewModel.hasBackup ? View.VISIBLE : View.GONE}"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space8dp"
                    android:text="@{ViewModel.num}"
                    android:textColor="@color/color_hint_text"
                    android:textSize="@dimen/textSize11Sp"/>

            </LinearLayout>

            <ImageView
                android:layout_width="@dimen/space24dp"
                android:layout_height="@dimen/space24dp"
                android:layout_gravity="center_vertical"
                android:layout_marginRight="@dimen/space12dp"
                android:src="@mipmap/ic_arrow_gray"/>

        </LinearLayout>

    </com.sandboxol.mapeditor.view.widget.LineItemView>

</layout>