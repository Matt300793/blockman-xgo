<resources>

    <style name="StartActivityTheme" parent="AppTheme">
        <item name="android:windowBackground">@mipmap/welcome</item>
    </style>

    <style name="FileIconStyle">
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_marginLeft">12dp</item>
    </style>

    <style name="FileNameStyle" parent="android:Widget.TextView">
        <item name="android:ellipsize">marquee</item>
        <item name="android:freezesText">true</item>
        <item name="android:gravity">left|center_vertical</item>
        <item name="android:layout_marginLeft">6dp</item>
        <item name="android:layout_marginRight">12dp</item>
        <item name="android:marqueeRepeatLimit">marquee_forever</item>
        <item name="android:scrollHorizontally">true</item>
        <item name="android:singleLine">true</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="MainItemViewStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginLeft">@dimen/space9dp</item>
        <item name="android:layout_marginRight">@dimen/space9dp</item>
    </style>

    <style name="TitleText12sp">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/textSize12Sp</item>
        <item name="android:textColor">@color/color_title_text</item>
    </style>

    <style name="TitleText14sp">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/textSize14Sp</item>
        <item name="android:textColor">@color/color_title_text</item>
    </style>

    <style name="SelectLandRadioButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:background">@drawable/bg_select_land</item>
        <item name="android:button">@null</item>
        <item name="android:drawableRight">@drawable/ic_select_land</item>
        <item name="android:paddingLeft">@dimen/space20dp</item>
        <item name="android:paddingRight">@dimen/space10dp</item>
        <item name="android:layout_marginTop">@dimen/space10dp</item>
        <item name="android:textColor">@color/color_select_land_text</item>
    </style>

    <style name="McMapIconStyle">
        <item name="android:layout_width">@dimen/map_icon_size</item>
        <item name="android:layout_height">@dimen/map_icon_size</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_marginLeft">@dimen/space12dp</item>
        <item name="android:layout_marginRight">@dimen/space10dp</item>
        <item name="android:src">@mipmap/ic_map_default</item>
    </style>

    <style name="SmallMcMapIconStyle">
        <item name="android:layout_width">@dimen/small_map_icon_size</item>
        <item name="android:layout_height">@dimen/small_map_icon_size</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_marginLeft">@dimen/space12dp</item>
        <item name="android:layout_marginRight">@dimen/space10dp</item>
        <item name="android:src">@mipmap/ic_map_default</item>
    </style>

    <style name="CircleCheckBoxStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:button">@null</item>
        <item name="android:layout_marginRight">@dimen/space12dp</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:drawableLeft">@drawable/ic_state</item>
    </style>

    <style name="EditorMapDialogItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@color/color_more_bg</item>
        <item name="android:textColor">@color/color_dialog_content_text</item>
        <item name="android:textSize">@dimen/textSize14Sp</item>
    </style>

    <style name="DialogButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/color_dialog_confirm_text</item>
        <item name="android:textSize">@dimen/textSize17Sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ListItemButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/color_dialog_confirm_text</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
    </style>

    <style name="ClearEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:background">@drawable/bg_clear_edit_text</item>
        <item name="android:paddingLeft">@dimen/space20dp</item>
        <item name="android:paddingRight">@dimen/space10dp</item>
        <item name="android:drawableRight">@mipmap/ic_clear</item>
        <item name="android:textColor">@color/color_dialog_content_text</item>
        <item name="android:textColorHint">@color/color_edit_hint_text</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="MapListItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">101dp</item>
        <item name="android:background">@color/color_more_bg</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="MapListItemContentStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:orientation">horizontal</item>
    </style>

</resources>
