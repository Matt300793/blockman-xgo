<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="MainItemView">
        <attr name="title" format="string"/>
        <attr name="backgroundRes" format="reference"/>
    </declare-styleable>

    <declare-styleable name="MapSizeView">
        <attr name="onSizeChangeCommand" format="reference"/>
    </declare-styleable>

    <declare-styleable name="RoundImageView">
        <attr name="borderRadius" format="dimension"/>
        <attr name="type">
            <enum name="circle" value="0"/>
            <enum name="round" value="1"/>
        </attr>
    </declare-styleable>

    <declare-styleable name="LineItemView">
        <attr name="lineColor" format="integer"/>
        <attr name="lineDirection">
            <enum name="left" value="9"/>
            <enum name="top" value="10"/>
            <enum name="right" value="11"/>
            <enum name="bottom" value="12"/>
        </attr>
    </declare-styleable>

</resources>