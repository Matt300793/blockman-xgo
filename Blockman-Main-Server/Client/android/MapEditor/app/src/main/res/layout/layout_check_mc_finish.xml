<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vFinish"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_check_mc_finish"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="6"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivMcIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="4dp"
            android:src="@mipmap/ic_minecraft"/>

        <TextView
            android:id="@+id/tvMcName"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/space12dp"
            android:gravity="center"
            android:text="@string/minecraft"
            android:textColor="@color/white"
            android:textSize="@dimen/textSize12Sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMcVersion"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/space4dp"
            android:gravity="center"
            android:text="1.2.6.0"
            android:textColor="@color/white"
            android:textSize="@dimen/textSize12Sp"/>

    </LinearLayout>

    <View
        android:layout_width="@dimen/lineH"
        android:layout_height="match_parent"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:background="#B2FF73"/>

    <LinearLayout
        android:id="@+id/llInstructions"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/space10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/use_instructions"
            android:textColor="@color/white"
            android:textSize="@dimen/textSize12Sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_margin="@dimen/space10dp"
            android:src="@mipmap/ic_arrow_green"/>

    </LinearLayout>

</LinearLayout>