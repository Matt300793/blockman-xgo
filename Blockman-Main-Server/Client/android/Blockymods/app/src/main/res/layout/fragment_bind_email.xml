<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="BindEmailViewModel"
            type="com.sandboxol.blockymods.view.fragment.bindemail.BindEmailViewModel"/>

        <import type="android.view.View"/>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/defaultMargin"
        android:layout_marginRight="@dimen/defaultMargin"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="@{BindEmailViewModel.isSend ? View.VISIBLE : View.GONE}"
            android:orientation="vertical">

            <EditText
                style="@style/EmailEditTextStyle"
                android:background="@color/itemDefaultColor"
                android:hint="@string/bind_email_hint"
                app:afterTextChangedCommand="@{BindEmailViewModel.onGetEmailTextCommand}"/>

            <Button
                style="@style/GreenButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:enabled="@{BindEmailViewModel.enable}"
                app:onClickCommand="@{BindEmailViewModel.onSendCodeCommand}"
                android:layout_marginTop="10dp"
                android:text="@string/next"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="@{BindEmailViewModel.isSend ? View.GONE : View.VISIBLE}"
            android:orientation="vertical">

            <EditText
                style="@style/EmailEditTextStyle"
                android:background="@color/itemDefaultColor"
                android:hint="@string/bind_phone_code_hint"
                android:inputType="number"
                android:maxLength="6"
                app:afterTextChangedCommand="@{BindEmailViewModel.onGetCodeCommand}"/>

            <Button
                style="@style/GreenButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                app:onClickCommand="@{BindEmailViewModel.onBindCommand}"
                android:layout_marginTop="10dp"
                android:text="@string/bind_email_bind"/>

        </LinearLayout>

    </LinearLayout>

</layout>