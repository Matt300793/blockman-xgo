<resources>

    <style name="StartActivityTheme" parent="AppTheme">
        <item name="android:windowBackground">@mipmap/welcome</item>
    </style>

    <!-- EditText样式 -->
    <style name="EditTextStyle" parent="Theme.AppCompat.Light">
        <item name="colorControlNormal">@color/editTextBottomColor</item>
        <item name="colorControlActivated">@color/editTextBottomColor</item>
    </style>

    <style name="MainItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/btn_main_item_text_selector</item>
        <item name="android:textSize">@dimen/textSize11Sp</item>
        <item name="android:button">@null</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">3dp</item>
    </style>

    <style name="AccountEditTextStyle">
        <item name="android:layout_width">270dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">@dimen/defaultMargin</item>
        <item name="android:textColorHint">@color/titleText</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:theme">@style/EditTextStyle</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLength">16</item>
        <item name="android:digits">
            1234567890qwertyuiopasdfghjklzxcvbnmQWERTYUIOPASDFGHJKLZXCVBNM,.?!@#_
        </item>
        <item name="android:ellipsize">end</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="NicknameEditTextStyle" parent="AccountEditTextStyle">
        <item name="android:layout_width">270dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">@dimen/defaultMargin</item>
        <item name="android:textColorHint">@color/titleText</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:theme">@style/EditTextStyle</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLength">16</item>
        <item name="android:ellipsize">end</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="PasswordEditTextStyle" parent="AccountEditTextStyle">
        <item name="android:inputType">textPassword</item>
    </style>

    <style name="GreenButtonStyle">
        <item name="android:layout_width">240dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/btn_green_selector</item>
    </style>

    <style name="MoreLoginButtonStyle">
        <item name="android:layout_width">57dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/btn_green_selector</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AccountThirdPartyTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/textSize12Sp</item>
        <item name="android:textColor">@color/titleText</item>
    </style>

    <style name="AccountSexSelectStyle">
        <item name="android:layout_width">115dp</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:background">@drawable/btn_account_sex_selector</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:textColor">@color/btn_account_sex_text_selector</item>
        <item name="android:button">@null</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ClearEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/itemDefaultHeight</item>
        <item name="android:background">@color/itemDefaultColor</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:textColor">@color/itemTextDefaultColor</item>
        <item name="android:textColorHint">@color/editTextHint</item>
        <item name="android:textSize">@dimen/textSize14Sp</item>
        <item name="android:digits">
            1234567890qwertyuiopasdfghjklzxcvbnmQWERTYUIOPASDFGHJKLZXCVBNM,.?!@#_
        </item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:inputType">textPassword</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="EmailEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/itemDefaultHeight</item>
        <item name="android:background">@color/itemDefaultColor</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:textColor">@color/itemTextDefaultColor</item>
        <item name="android:textColorHint">@color/editTextHint</item>
        <item name="android:textSize">@dimen/textSize14Sp</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:inputType">textEmailAddress</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="NickNameClearStyle" parent="ClearEditTextStyle">
        <item name="android:digits">
            1234567890qwertyuiopasdfghjklzxcvbnmQWERTYUIOPASDFGHJKLZXCVBNM_
        </item>
    </style>

    <style name="ClearButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:padding">10dp</item>
        <item name="android:src">@mipmap/ic_clear</item>
    </style>

    <style name="GameFragmentTitleTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:textColor">@color/btn_game_title_text_selector</item>
        <item name="android:button">@null</item>
    </style>

    <style name="GameFragmentSecondTitleStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">7dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:layout_marginLeft">@dimen/defaultMargin</item>
        <item name="android:layout_marginRight">@dimen/defaultMargin</item>
        <item name="android:drawableLeft">@mipmap/ic_game_text_drawable</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:textColor">@color/gameRecommendTextColor</item>
        <item name="android:textSize">@dimen/textSize15Sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CategoryFragmentItemStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_marginLeft">5dp</item>
        <item name="android:layout_marginRight">5dp</item>
        <item name="android:button">@null</item>
        <item name="android:textColor">@color/btn_category_item_text_selector</item>
        <item name="android:background">@drawable/btn_category_item_bg_selector</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">10dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">@dimen/textSize12Sp</item>
    </style>

    <style name="DressRadioButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:button">@null</item>
    </style>

</resources>
