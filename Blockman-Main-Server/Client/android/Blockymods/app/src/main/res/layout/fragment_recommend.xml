<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:bind="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="RecommendViewModel"
            type="com.sandboxol.blockymods.view.fragment.recommend.RecommendViewModel"/>

        <import type="me.tatarka.bindingcollectionadapter.LayoutManagers"/>

        <import type="android.support.v7.widget.LinearLayoutManager"/>

        <import type="android.view.View"/>
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mainBgColor"
        android:orientation="vertical">

        <android.support.v4.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="60dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="156dp"
                    android:background="@drawable/bg_banner">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@mipmap/ic_banner_default"/>

                </RelativeLayout>

                <TextView
                    style="@style/GameFragmentSecondTitleStyle"
                    android:text="@string/game_fragment_recommend"/>

                <com.sandboxol.common.widget.rv.datarv.DataRecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    bind:layoutFactory="@{LayoutManagers.grid(2)}"
                    bind:listLayout="@{RecommendViewModel.gameListLayout}"
                    bind:model="@{RecommendViewModel.hotRecommendModel}"/>

                <LinearLayout
                    android:layout_width="184dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/btn_green_selector"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingBottom="0dp"
                    android:paddingTop="0dp"
                    bind:onClickCommand="@{RecommendViewModel.onClickChangeCommand}">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/anim_game_change"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginLeft="5dp"
                        android:drawablePadding="5dp"
                        android:lines="1"
                        android:text="@string/game_fragment_change"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/textSize14Sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    style="@style/GameFragmentSecondTitleStyle"
                    android:layout_marginTop="20dp"
                    android:text="@string/game_fragment_lately_play"
                    android:visibility="@{RecommendViewModel.isShowRecently ? View.VISIBLE : View.GONE}"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbarAlwaysDrawHorizontalTrack="false"
                    android:scrollbars="none"
                    android:visibility="@{RecommendViewModel.isShowRecently ? View.VISIBLE : View.GONE}">

                    <com.sandboxol.common.widget.rv.datarv.DataRecyclerView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        bind:layoutFactory="@{LayoutManagers.linear(LinearLayoutManager.HORIZONTAL, false)}"
                        bind:listLayout="@{RecommendViewModel.gameListLayout}"
                        bind:model="@{RecommendViewModel.latelyPlayModel}"/>

                </HorizontalScrollView>

                <TextView
                    style="@style/GameFragmentSecondTitleStyle"
                    android:layout_marginTop="20dp"
                    android:text="@string/game_fragment_friend_play"
                    android:visibility="@{RecommendViewModel.isShowFriend ? View.VISIBLE : View.GONE}"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbarAlwaysDrawHorizontalTrack="false"
                    android:scrollbars="none"
                    android:visibility="@{RecommendViewModel.isShowFriend ? View.VISIBLE : View.GONE}">

                    <com.sandboxol.common.widget.rv.datarv.DataRecyclerView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        bind:layoutFactory="@{LayoutManagers.linear(LinearLayoutManager.HORIZONTAL, false)}"
                        bind:listLayout="@{RecommendViewModel.gameListLayout}"
                        bind:model="@{RecommendViewModel.friendPlayModel}"/>

                </HorizontalScrollView>

            </LinearLayout>

        </android.support.v4.widget.NestedScrollView>


    </LinearLayout>

</layout>