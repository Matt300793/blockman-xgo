<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    >

    <data>

        <variable
            name="ReminderViewModel"
            type="com.sandboxol.blockymods.view.fragment.reminder.ReminderViewModel"/>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/itemDefaultHeight"
            android:background="@color/itemDefaultColor"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingRight="@dimen/defaultMargin">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/defaultMargin"
                android:layout_weight="1"
                android:text="@string/reminder_open_remind"
                android:textColor="@color/itemTextDefaultColor"
                android:textSize="@dimen/textSize15Sp"/>

            <CheckBox
                android:layout_width="50dp"
                android:layout_height="27dp"
                android:background="@drawable/ic_cb_close_open_selector"
                android:button="@null"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/borderLineHeight"
            android:background="@color/borderLineColor"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/itemDefaultHeight"
            android:background="@color/itemDefaultColor"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingRight="@dimen/defaultMargin">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/defaultMargin"
                android:layout_weight="1"
                android:text="@string/reminder_open_personal"
                android:textColor="@color/itemTextDefaultColor"
                android:textSize="@dimen/textSize15Sp"/>

            <CheckBox
                android:layout_width="50dp"
                android:layout_height="27dp"
                android:background="@drawable/ic_cb_close_open_selector"
                android:button="@null"/>

        </LinearLayout>


    </LinearLayout>

</layout>