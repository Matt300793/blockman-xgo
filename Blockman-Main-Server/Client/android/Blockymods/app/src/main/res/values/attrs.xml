<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="MeItemView">
        <attr name="drawableLeft" format="reference"/>
        <attr name="isShowPoint" format="boolean"/>
        <attr name="text" format="string"/>
        <attr name="background" format="reference"/>
        <attr name="isShowBorder" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="ItemView">
        <attr name="showPoint" format="boolean"/>
        <attr name="leftText" format="string"/>
        <attr name="rightText" format="string"/>
        <attr name="rightTextHint" format="string"/>
        <attr name="border" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="AutoSizeView">
        <attr name="isAutoWidth" format="boolean"/>
        <attr name="widthProportion" format="integer"/>
        <attr name="heightProportion" format="integer"/>
    </declare-styleable>
</resources>