<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/llItem"
              android:layout_width="match_parent"
              android:layout_height="@dimen/itemDefaultHeight"
              android:background="@color/itemDefaultColor"
              android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingRight="@dimen/defaultMargin">

        <TextView
            android:id="@+id/tvLeftText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/defaultMargin"
            android:text="@string/item_view_nick_name"
            android:textColor="@color/itemTextDefaultColor"
            android:textSize="@dimen/textSize15Sp"/>

        <TextView
            android:id="@+id/tvRightText"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:ellipsize="end"
            android:gravity="right"
            android:maxEms="10"
            android:maxLines="1"
            android:textColor="@color/itemTextHintColor"
            android:textSize="@dimen/textSize12Sp"/>

        <ImageView
            android:id="@+id/ivArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/defaultMargin"
            android:src="@mipmap/ic_arrow_right"/>

    </LinearLayout>

    <View
        android:id="@+id/vLine"
        android:layout_width="match_parent"
        android:layout_height="@dimen/borderLineHeight"
        android:background="@color/borderLineColor"/>

</LinearLayout>